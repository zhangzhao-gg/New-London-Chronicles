{
  "name": "new-london-chronicles",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:young": "NODE_TLS_REJECT_UNAUTHORIZED=0 next dev",
    "build": "next build",
    "start": "next start",
    "start:young": "NODE_TLS_REJECT_UNAUTHORIZED=0 next start",
    "typecheck": "npm run --silent build && tsc --noEmit",
    "test:e2e": "NODE_TLS_REJECT_UNAUTHORIZED=0 npm run --silent build && NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "dependencies": {
    "next": "15.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.1.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "tailwindcss": "4.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  }
}
